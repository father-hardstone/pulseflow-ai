# Base URL of the deployed backend API (leave empty in dev to use the Vite proxy).
# Example: https://your-backend.vercel.app
VITE_API_BASE_URL=

# Used only by the dev server proxy (defaults to http://localhost:3000)
VITE_BACKEND_URL=http://localhost:3000

# Log OCR extract output in browser devtools during ingest (on by default in dev; set 0 to disable)
# VITE_DEBUG_OCR=1
