# ----- Server -----
PORT=3000
# Comma-separated allowed origins for CORS (e.g. http://localhost:5173,https://yourapp.vercel.app)
CORS_ORIGINS=

# ----- JWT auth (REQUIRED for users) -----
# Use long random strings (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----- Admin JWT auth (REQUIRED for /api/admin/*) -----
# Must be different secrets from user JWT above.
JWT_ADMIN_ACCESS_SECRET=
JWT_ADMIN_REFRESH_SECRET=
JWT_ADMIN_ACCESS_TTL=15m
JWT_ADMIN_REFRESH_TTL=7d

# First super_admin (created once on server start if no admins exist)
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# Shared secret n8n sends (x-worker-secret) when calling /api/worker/* (REQUIRED for campaigns)
WORKER_SHARED_SECRET=

# ----- LLM (outreach generation) -----
# Provider: gemini | groq
LLM_PROVIDER=gemini

# Google Gemini via LangChain
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Groq via LangChain (set LLM_PROVIDER=groq to use)
GROQ_API_KEY=
GROQ_MODEL_TEXT=llama-3.3-70b-versatile
# Vision model for OCR on images and scanned PDFs
GROQ_MODEL_VISION=meta-llama/llama-4-scout-17b-16e-instruct

# OCR ingest tuning
OCR_MIN_TEXT_CHARS=40
OCR_MAX_PDF_PAGES=25
OCR_PDF_SCALE=1.5

# ----- Supabase: Postgres + pgvector + auth identity (REQUIRED) -----
# API keys (Project Settings -> API):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Database password (Project Settings -> Database). Used by: npm run db:migrate
SUPABASE_DB_PASSWORD=
# Or set full connection string instead of SUPABASE_DB_PASSWORD:
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ----- HuggingFace embeddings (REQUIRED for knowledge base) -----
# Either variable works; HF_TOKEN is a common alias.
HUGGINGFACE_API_KEY=
# HF_TOKEN=
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ----- Apollo.io (used by the n8n workflow; key also validated by backend) -----
APOLLO_API_KEY=
# Free-tier guardrails — one search uses ~per_page credits. Defaults are conservative.
APOLLO_DEFAULT_LEADS_PER_CAMPAIGN=1
APOLLO_MAX_LEADS_PER_CAMPAIGN=10
APOLLO_MAX_LEADS_PER_USER_MONTH=25
APOLLO_MAX_LEADS_PER_MONTH=50

# ----- Hunter.io (cold prospecting via Discover + Domain Search) -----
HUNTER_API_KEY=

# ----- n8n (REQUIRED to launch Apollo campaigns) -----
# Set in backend/.env ONLY — the frontend never calls n8n directly.
# Local Docker (workflow path: pulseflow-launch, workflow must be Active in n8n UI):
N8N_LAUNCH_WEBHOOK_URL=http://localhost:5678/webhook/pulseflow-launch
# Production: paste the Production Webhook URL from the n8n Launch node.

# ----- Resend (real test inboxes when demo target = real) -----
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=PulseFlow AI

# ----- Mailtrap Email Sandbox (demo target = mailtrap) -----
MAILTRAP_API_TOKEN=
MAILTRAP_FROM_EMAIL=pulseflow@demo.mailtrap.io
MAILTRAP_FROM_NAME=PulseFlow AI

# ----- YouTube transcript ingest (optional) -----
# Preferred caption languages, tried in order (BCP-47 codes).
YOUTUBE_TRANSCRIPT_LANGS=en,en-US
